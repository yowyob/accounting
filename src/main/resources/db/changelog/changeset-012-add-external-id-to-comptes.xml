<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-add-external-id-to-comptes" author="system">
        <comment>Add external_id column to comptes table for cross-module references</comment>
        
        <addColumn tableName="comptes">
            <column name="external_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        
        <createIndex indexName="idx_comptes_external_id" tableName="comptes">
            <column name="external_id"/>
        </createIndex>
        
        <rollback>
            <dropIndex indexName="idx_comptes_external_id" tableName="comptes"/>
            <dropColumn tableName="comptes" columnName="external_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
