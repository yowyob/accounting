<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-fix-comptes-constraints" author="delmat">
        <comment>Drop incorrect unique constraints and add composite tenant-aware constraint</comment>
        
        <!-- Drop the ghost unique constraint on type_compte -->
        <dropUniqueConstraint tableName="comptes" constraintName="comptes_type_compte_key"/>
        
        <!-- Drop the global unique constraint on no_compte if it exists -->
        <!-- Note: The name depends on how Hibernate generated it, usually UK_... or comptes_no_compte_key -->
        <rollback>
            <!-- Hard to rollback dropping a ghost constraint exactly, but safe to ignore -->
        </rollback>
    </changeSet>

    <changeSet id="004-add-composite-unique-compte" author="delmat">
        <comment>Ensure account numbers are unique per tenant</comment>
        
        <!-- Drop potential hibernate-generated unique constraint on no_compte -->
        <sql suppressErrors="true">
            ALTER TABLE comptes DROP CONSTRAINT IF EXISTS uk_comptes_no_compte;
            ALTER TABLE comptes DROP CONSTRAINT IF EXISTS comptes_no_compte_key;
        </sql>

        <addUniqueConstraint tableName="comptes" 
                             columnNames="tenant_id, no_compte" 
                             constraintName="uk_comptes_tenant_no_compte"/>
    </changeSet>

</databaseChangeLog>
