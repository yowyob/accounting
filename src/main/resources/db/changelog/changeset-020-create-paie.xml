<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="020-create-paie" author="yowyob-system">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="lignes_paie"/></not>
        </preConditions>

        <createTable tableName="lignes_paie">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_lignes_paie" nullable="false"/>
            </column>
            <column name="organization_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="exercice_id" type="UUID">
                <constraints nullable="false"
                    foreignKeyName="fk_paie_exercice"
                    referencedTableName="exercices_comptables" referencedColumnNames="id"/>
            </column>
            <column name="periode_id" type="UUID">
                <constraints foreignKeyName="fk_paie_periode"
                    referencedTableName="periodes_comptables" referencedColumnNames="id"/>
            </column>
            <column name="mois_paie" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(255)"/>

            <!-- Salaires -->
            <column name="salaire_brut_total" type="NUMERIC(18,2)">
                <constraints nullable="false"/>
            </column>
            <column name="retenue_cnps_salarie" type="NUMERIC(18,2)" defaultValueNumeric="0"/>
            <column name="retenue_irpp" type="NUMERIC(18,2)" defaultValueNumeric="0"/>
            <column name="autres_retenues" type="NUMERIC(18,2)" defaultValueNumeric="0"/>
            <column name="salaire_net_total" type="NUMERIC(18,2)">
                <constraints nullable="false"/>
            </column>

            <!-- Charges patronales -->
            <column name="charge_patronale_cnps" type="NUMERIC(18,2)" defaultValueNumeric="0"/>
            <column name="autres_charges_patronales" type="NUMERIC(18,2)" defaultValueNumeric="0"/>

            <!-- Statut et lien vers l'écriture -->
            <column name="statut" type="VARCHAR(20)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="ecriture_id" type="UUID">
                <constraints foreignKeyName="fk_paie_ecriture"
                    referencedTableName="ecritures_comptables" referencedColumnNames="id"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_by" type="VARCHAR(255)"/>
        </createTable>

        <createIndex tableName="lignes_paie" indexName="idx_paie_org">
            <column name="organization_id"/>
        </createIndex>
        <createIndex tableName="lignes_paie" indexName="idx_paie_exercice">
            <column name="exercice_id"/>
        </createIndex>
        <createIndex tableName="lignes_paie" indexName="idx_paie_periode">
            <column name="periode_id"/>
        </createIndex>
        <createIndex tableName="lignes_paie" indexName="idx_paie_statut">
            <column name="statut"/>
        </createIndex>
        <createIndex tableName="lignes_paie" indexName="idx_paie_mois">
            <column name="mois_paie"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
