<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="004-create-taxes-table" author="yowyob-system">
        <comment>Création de la table taxes et de ses contraintes.</comment>

        <createTable tableName="taxes">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_taxes" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="taux" type="NUMERIC(5, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="compte_collecte" type="VARCHAR(20)"/>
            <column name="compte_deductible" type="VARCHAR(20)"/>
            <column name="pays" type="VARCHAR(50)"/>
            <column name="date_debut_validite" type="DATE"/>
            <column name="date_fin_validite" type="DATE"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="taxes"
            baseColumnNames="tenant_id"
            constraintName="fk_taxes_tenant"
            referencedTableName="tenants"
            referencedColumnNames="id"/>

        <addUniqueConstraint
            tableName="taxes"
            columnNames="tenant_id, code"
            constraintName="uk_taxes_tenant_code"/>

        <createIndex tableName="taxes" indexName="idx_taxes_tenant_code">
            <column name="tenant_id"/>
            <column name="code"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
