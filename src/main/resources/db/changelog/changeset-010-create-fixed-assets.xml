<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="010-create-fixed-assets" author="yowyob-system">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="immobilisations" />
            </not>
        </preConditions>

        <comment>Création des tables pour la gestion des immobilisations et des amortissements.</comment>

        <createTable tableName="immobilisations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_immobilisations" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="date_acquisition" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="valeur_origine" type="NUMERIC(18, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="duree_vie" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="methode_amortissement" type="VARCHAR(20)" defaultValue="LINEAIRE">
                <constraints nullable="false"/>
            </column>
            <column name="compte_immo_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_immo_compte_immo" referencedTableName="comptes" referencedColumnNames="id"/>
            </column>
            <column name="compte_amort_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_immo_compte_amort" referencedTableName="comptes" referencedColumnNames="id"/>
            </column>
            <column name="compte_dotation_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_immo_compte_dot" referencedTableName="comptes" referencedColumnNames="id"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="valeur_residuelle" type="NUMERIC(18, 2)" defaultValueNumeric="0"/>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_by" type="VARCHAR(255)"/>
        </createTable>

        <createTable tableName="amortissements_lignes">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_amortissements_lignes" nullable="false"/>
            </column>
            <column name="immo_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_amort_immo" referencedTableName="immobilisations" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="exercice_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_amort_exercice" referencedTableName="exercices_comptables" referencedColumnNames="id"/>
            </column>
            <column name="date_echeance" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="base_calcul" type="NUMERIC(18, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="taux" type="NUMERIC(5, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="annuite" type="NUMERIC(18, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="cumul_amortissement" type="NUMERIC(18, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="valeur_nette_comptable" type="NUMERIC(18, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="comptabilisee" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="ecriture_id" type="UUID">
                <constraints foreignKeyName="fk_amort_ecriture" referencedTableName="ecritures_comptables" referencedColumnNames="id"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="immobilisations" columnNames="tenant_id, code" constraintName="uk_immo_tenant_code"/>
    </changeSet>

</databaseChangeLog>
