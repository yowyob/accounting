<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="025-create-unites-oeuvre" author="leonel">
        <!-- 1. Création de la table unites_oeuvre -->
        <createTable tableName="unites_oeuvre">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_unites_oeuvre" nullable="false"/>
            </column>
            <column name="organization_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="unite" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="centre_id" type="UUID">
                <constraints foreignKeyName="fk_unite_oeuvre_centre" referencedTableName="axes_analytiques" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="cout_unitaire_previsionnel" type="NUMERIC(18,4)"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITHOUT TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_by" type="VARCHAR(255)"/>
        </createTable>

        <createIndex tableName="unites_oeuvre" indexName="idx_unites_oeuvre_org">
            <column name="organization_id"/>
        </createIndex>

        <addUniqueConstraint tableName="unites_oeuvre" columnNames="organization_id, code" constraintName="uq_unites_oeuvre_org_code"/>
    </changeSet>
</databaseChangeLog>
