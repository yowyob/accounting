# ==============================================================
# 🏭 YOWYOB-ERP-ACCOUNTING — .env de PRODUCTION (serveur yowyob)
# ==============================================================
# Copier en ".env" SUR LE SERVEUR (dans /home/gi/accounting/) et compléter.
# NE JAMAIS committer le .env rempli (gitignoré).
# Les variables non secrètes (DB_HOST, KAFKA, AUTH_*, etc.) sont déjà fixées
# dans docker-compose.prod.yml -> ici, uniquement ce qui est secret/spécifique.
# ==============================================================

# Image construite localement par le CI (le job deploy passe ACCOUNTING_IMAGE).
# Déploiement manuel : renseigner le tag local construit sur le serveur.
ACCOUNTING_IMAGE=accounting/backend:main

# Mot de passe du rôle PostgreSQL "accounting" (base dédiée "accounting")
ACCOUNTING_DB_PASSWORD=__A_RENSEIGNER__

# Mot de passe du user Kafka "accounting" (SASL/SCRAM-SHA-256)
ACCOUNTING_KAFKA_PASSWORD=__A_RENSEIGNER__

# Secret du client kernel-core dédié "accounting-backend"
# (généré par POST /api/client-applications côté kernel-core)
ACCOUNTING_KERNEL_CLIENT_SECRET=__A_RENSEIGNER__

# Secret JWT applicatif local (>= 32 caractères) : openssl rand -base64 48
ACCOUNTING_JWT_SECRET=__A_RENSEIGNER__

# Tenant par défaut (plateforme yowyob)
ACCOUNTING_TENANT_ID=11111111-1111-1111-1111-111111111111

# Origines CORS autorisées (front accounting + dev) — séparées par des virgules
ACCOUNTING_CORS_ORIGINS=https://accounting.yowyob.com,http://localhost:3000
