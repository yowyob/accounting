# ==============================================================
# 🌍 YOWYOB ERP - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================
# Copiez ce fichier sous le nom ".env" et remplissez les vraies valeurs.
# Ce fichier est ignoré par Git pour protéger les secrets.

# ==============================================================
# 🖥️ DEV LOCAL — notes
# ==============================================================
# Docker (docker-compose.shared.yml) : DB_HOST=postgres, DB_PORT=5432, KAFKA=kafka:29092
# JAR local (java -jar)            : DB_HOST=localhost, DB_PORT=5433 (iwm-postgres mappé)
# Frontend                         : NEXT_PUBLIC_API_URL=http://localhost:8081
# CORS                             : CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================
# 🗄️ DATABASE (PostgreSQL)
# ==============================================================
POSTGRES_DB=yowyob_erp
POSTGRES_USER=yowyob_admin
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_HOST=postgres
DB_PORT=5432
DB_NAME=yowyob_erp

# ==============================================================
# 🔥 REDIS (Cache)
# ==============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ==============================================================
# 🔐 JWT SECURITY
# ==============================================================
JWT_SECRET=replace_with_strong_secret_base64_key
JWT_EXPIRATION=86400000

# ==============================================================
# 📨 KAFKA (Async Events)
# ==============================================================
KAFKA_BOOTSTRAP=kafka:29092

# ==============================================================
# 🔎 ELASTICSEARCH (Search Engine)
# ==============================================================
ELASTICSEARCH_URI=http://elasticsearch:9200

# ==============================================================
# 🧱 LIQUIBASE / MIGRATION
# ==============================================================
LIQUIBASE_CHANGELOG=classpath:db/changelog/changelog-master.xml
LIQUIBASE_SCHEMA=public

# ==============================================================
# 🌐 AUTHENTICATION / EXTERNAL API
# ==============================================================
AUTH_API_URL=http://localhost:8080
AUTH_API_TIMEOUT=5000
AUTH_API_RETRIES=3

# ==============================================================
# 🌐 CORS (Frontend)
# ==============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================
# 🏢 MULTI-TENANT
# ==============================================================
TENANT_DEFAULT=4e177ff2-89b8-4d24-926a-5763dfa1b19a
app.organization.default-organization=4e177ff2-89b8-4d24-926a-5763dfa1b19a

# ==============================================================
# ⚙️ APP SETTINGS
# ==============================================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8081
